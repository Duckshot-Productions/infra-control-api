# Control API Token (generate with: openssl rand -hex 32)
CONTROL_TOKEN=your-secret-token-here

# Tailscale IP of this VPS
TAILSCALE_IP=100.x.x.x

# Database
DATABASE_URL=postgresql://user:pass@localhost/infradb

# Redis
REDIS_URL=redis://localhost:6379/0

# LLM Endpoints
QWEN_LOCAL_URL=http://localhost:8080/v1
QWEN_CLOUD_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_API_KEY=your-qwen-api-key
GEMINI_API_KEY=your-gemini-api-key

# CORS
ALLOWED_ORIGINS=*
